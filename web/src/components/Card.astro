---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, author, ogImage, ...props } = data;

// ogImage가 문자열이면 그대로 사용, 객체면 src 사용
const thumbnailUrl = typeof ogImage === "string" ? ogImage : ogImage?.src;
---

<li class="group card-hover glass my-6 overflow-hidden rounded-xl bg-muted/30">
  <a
    href={getPath(id, filePath)}
    class="grid gap-8 p-6 sm:grid-cols-12"
  >
    {thumbnailUrl && (
      <div class="sm:col-span-4 overflow-hidden rounded-lg">
        <img 
          src={thumbnailUrl} 
          alt={title} 
          class="h-48 w-full object-cover grayscale-[0.2] transition-all duration-500 group-hover:scale-105 group-hover:grayscale-0 sm:h-full"
        />
      </div>
    )}
    <div class:list={["flex flex-col justify-center", thumbnailUrl ? "sm:col-span-8" : "sm:col-span-12"]}>
      <Heading
        transition:name={slugifyStr(title.replaceAll(".", "-"))}
        class="text-xl font-bold tracking-tight text-foreground sm:text-2xl"
      >
        {title}
      </Heading>
      
      <div class="mt-3 flex items-center gap-4 text-sm font-medium text-slate-500 dark:text-slate-400">
        <span class="flex items-center gap-1.5">
          <span class="size-1.5 rounded-full bg-accent"></span>
          {author}
        </span>
        <span>•</span>
        <Datetime {...props} />
      </div>

      <p class="mt-4 line-clamp-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
        {description}
      </p>
    </div>
  </a>
</li>
