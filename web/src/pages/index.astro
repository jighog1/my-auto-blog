---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" data-base-url={import.meta.env.BASE_URL} class="app-layout">
    <section id="hero" class="py-16 sm:py-24">
      <div class="glass relative overflow-hidden rounded-3xl p-8 sm:p-12">
        <div class="relative z-10">
          <h1 class="mb-6 text-4xl font-extrabold tracking-tight sm:text-6xl">
            AI-Driven <span class="text-accent underline decoration-accent/30 decoration-8 underline-offset-8">Insights</span>
          </h1>
          <p class="max-w-2xl text-lg leading-relaxed opacity-90 sm:text-xl">
            최신 글로벌 트렌드와 기술적 통찰을 AI가 분석하여 매일 자동으로 전해드립니다. 
            단순한 정보 수집을 넘어, 비즈니스와 기술의 미래를 먼저 만나보세요.
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-6">
            <Socials />
            <a
              target="_blank"
              href={`${import.meta.env.BASE_URL}rss.xml`}
              class="flex items-center gap-2 font-semibold text-accent hover:underline"
              aria-label="rss feed"
              title="RSS Feed"
            >
              <IconRss width={24} height={24} class="stroke-3" />
              구독하기
            </a>
          </div>
        </div>
        
        <!-- Decorative background element -->
        <div class="absolute -top-24 -right-24 h-64 w-64 rounded-full bg-accent/10 blur-3xl"></div>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={`${import.meta.env.BASE_URL}posts/`}>
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    const baseUrl = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.baseUrl;
    if (indexLayout && baseUrl) {
      sessionStorage.setItem("backUrl", baseUrl);
    }
  });
</script>
